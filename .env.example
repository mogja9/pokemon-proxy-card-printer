# ============================================================
# ProxyForge environment (copy to .env; .env is gitignored)
# Everything here is FREE / self-hostable. No paid keys required.
# ============================================================

# --- Database (Postgres 16 + pg_bigm, built from db/Dockerfile) ---
POSTGRES_USER=proxyforge
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=proxyforge
# Used by app code / migrate / ingest. Host is the compose service name.
DATABASE_URL=postgresql://proxyforge:change_me_locally@localhost:5432/proxyforge

# --- Data source: TCGdex (the SPINE) ---
# Production: point at your self-hosted tcgdex/cards-database clone so you do
# NOT hammer the public API (e.g. http://tcgdex:3000/v2).
# Dev default: the public API (be polite; ingest is rate-limited).
TCGDEX_BASE_URL=https://api.tcgdex.net/v2

# Languages to ingest (comma-separated). Western langs (en,fr,de,it,es,pt) share
# set IDs and collapse into one card_print row; ja/ko/zh-* are their own sets/rows.
LAUNCH_LANGS=en,ja,fr,de,it,es,pt,ko,zh-cn,zh-tw

# --- Overlay enrichment source (DEPRECATED; OFF by default) ---
# pokemontcg.io merged into paid Scrydex. Keep 'none' for the fully-$0 path.
# Options: none | ptcgio | scrydex
OVERLAY_ADAPTER=none
# Only used if OVERLAY_ADAPTER=ptcgio (free key, 20k/day). Leave blank otherwise.
POKEMONTCG_IO_API_KEY=

# --- Ingestion politeness (requests/sec per host) ---
INGEST_TCGDEX_RPS=4
INGEST_SCRAPE_RPS=0.5

# --- Object storage (SeaweedFS S3, Phase 2) ---
S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=proxyforge
S3_SECRET_KEY=change_me_locally
S3_BUCKET_SOURCE=pf-src
S3_BUCKET_ARTIFACTS=pf-artifacts

# --- Search (Meilisearch, Phase 3) ---
MEILI_MASTER_KEY=change_me_locally
MEILI_URL=http://localhost:7700
# Search backend: meili | pg  (pg = Postgres FTS + pg_bigm fallback)
SEARCH_BACKEND=meili

# --- Queue/cache (Valkey, Phase 4) ---
REDIS_URL=redis://localhost:6379

# --- Compliance posture (see packages/config/src/index.ts) ---
# generate-don't-host default; ephemeral image TTL; low profile.
COMPLIANCE_DEFAULT_SERVING_MODE=ephemeral
COMPLIANCE_NOINDEX=true
COMPLIANCE_PRICING_ENABLED=false
COMPLIANCE_CARD_BACK=none
